{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS; Database=AuthForge; Trusted_Connection=True; TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "UseSecretFromUserSecrets",
    "Issuer": "AuthForge",
    "Audience": "AuthForgeClients",
    "ExpirationInMinutes": 120
  }
}
